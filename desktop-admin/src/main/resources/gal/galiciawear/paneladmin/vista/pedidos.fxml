<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorPedidos"
      spacing="14" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Pedidos" styleClass="titulo-vista"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Estado:"/>
        <ComboBox fx:id="filtroEstado"/>
        <Button text="Refrescar" onAction="#refrescar" styleClass="boton-secundario"/>
    </HBox>

    <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNumero" text="Nº pedido" prefWidth="170"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="150"/>
            <TableColumn fx:id="colTotal" text="Total (€)" prefWidth="110"/>
            <TableColumn fx:id="colMetodo" text="Pago" prefWidth="130"/>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="200"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="botonCancelar" text="Cancelar pedido" onAction="#cancelar" styleClass="boton-peligro"/>
    </HBox>
</VBox>
