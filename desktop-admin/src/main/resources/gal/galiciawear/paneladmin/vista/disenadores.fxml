<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorDisenadores"
      spacing="14" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Diseñadores" styleClass="titulo-vista"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Filtro:"/>
        <ComboBox fx:id="filtroEstado"/>
        <Button text="Refrescar" onAction="#refrescar" styleClass="boton-secundario"/>
    </HBox>

    <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colMarca" text="Marca" prefWidth="220"/>
            <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="140"/>
            <TableColumn fx:id="colValidado" text="Estado" prefWidth="120"/>
            <TableColumn fx:id="colWeb" text="Web" prefWidth="220"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="botonAprobar" text="Aprobar" onAction="#aprobar" styleClass="boton-primario"/>
        <Button fx:id="botonRechazar" text="Rechazar" onAction="#rechazar" styleClass="boton-peligro"/>
    </HBox>
</VBox>
