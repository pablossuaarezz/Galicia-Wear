<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorDashboard"
      spacing="16" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Dashboard" styleClass="titulo-vista"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="etiquetaActualizado" styleClass="texto-tenue"/>
        <Button text="Refrescar" onAction="#refrescar" styleClass="boton-secundario"/>
    </HBox>

    <FlowPane fx:id="panelTarjetas" hgap="14" vgap="14"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Pedidos por estado" styleClass="subtitulo"/>
            <PieChart fx:id="graficoEstados" legendVisible="true" labelsVisible="true"
                      VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>
</VBox>
