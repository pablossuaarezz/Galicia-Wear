<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorProductos"
      spacing="14" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Productos" styleClass="titulo-vista"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="campoBusqueda" promptText="Buscar..." prefWidth="200"/>
        <ComboBox fx:id="filtroEstado"/>
        <Button text="Refrescar" onAction="#refrescar" styleClass="boton-secundario"/>
    </HBox>

    <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="240"/>
            <TableColumn fx:id="colMarca" text="Marca" prefWidth="170"/>
            <TableColumn fx:id="colPrecio" text="Precio (€)" prefWidth="100"/>
            <TableColumn fx:id="colMaterial" text="Material" prefWidth="150"/>
            <TableColumn fx:id="colActivo" text="Activo" prefWidth="90"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="botonAlternar" text="Activar / Desactivar" onAction="#alternarActivo" styleClass="boton-primario"/>
        <Button fx:id="botonRetirar" text="Retirar" onAction="#retirar" styleClass="boton-peligro"/>
    </HBox>
</VBox>
