<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorLogs"
      spacing="14" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Logs de auditoría" styleClass="titulo-vista"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="campoAccion" promptText="Acción (LOGIN...)" prefWidth="160"/>
        <TextField fx:id="campoRecurso" promptText="Recurso (producto...)" prefWidth="160"/>
        <Button text="Filtrar" onAction="#refrescar" styleClass="boton-secundario"/>
    </HBox>

    <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="200"/>
            <TableColumn fx:id="colAccion" text="Acción" prefWidth="150"/>
            <TableColumn fx:id="colRecurso" text="Recurso" prefWidth="130"/>
            <TableColumn fx:id="colUsuario" text="Usuario" prefWidth="220"/>
            <TableColumn fx:id="colIp" text="IP" prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
