<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorLogin"
      alignment="CENTER" spacing="14" styleClass="pantalla-login">
    <padding>
        <Insets top="48" right="48" bottom="48" left="48"/>
    </padding>

    <Label text="GaliciaWear" styleClass="marca-titulo"/>
    <Label text="Panel de administración" styleClass="marca-subtitulo"/>

    <VBox spacing="10" maxWidth="320">
        <Label text="Correo electrónico"/>
        <TextField fx:id="campoCorreo" promptText="admin@galiciawear.gal"/>
        <Label text="Contraseña"/>
        <PasswordField fx:id="campoContrasena" promptText="••••••••" onAction="#alEntrar"/>
    </VBox>

    <Button fx:id="botonEntrar" text="Entrar" defaultButton="true"
            onAction="#alEntrar" styleClass="boton-primario" maxWidth="320"/>

    <ProgressIndicator fx:id="indicadorCarga" visible="false" managed="false" prefHeight="28" prefWidth="28"/>
    <Label fx:id="etiquetaError" styleClass="etiqueta-error" wrapText="true" maxWidth="320"/>
</VBox>
