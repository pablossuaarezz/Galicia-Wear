<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gal.galiciawear.paneladmin.controlador.ControladorImportExport"
      spacing="16" styleClass="vista">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <Label text="Importar / Exportar catálogo" styleClass="titulo-vista"/>

    <Label text="Exportar el catálogo completo a un fichero:" styleClass="subtitulo"/>
    <HBox spacing="10">
        <Button text="Exportar a JSON" onAction="#exportarJson" styleClass="boton-primario"/>
        <Button text="Exportar a XML" onAction="#exportarXml" styleClass="boton-primario"/>
    </HBox>

    <Label text="Importar productos desde un fichero JSON o XML:" styleClass="subtitulo"/>
    <HBox spacing="10">
        <Button text="Importar JSON..." onAction="#importarJson" styleClass="boton-secundario"/>
        <Button text="Importar XML..." onAction="#importarXml" styleClass="boton-secundario"/>
    </HBox>

    <Label text="Resultado:" styleClass="subtitulo"/>
    <TextArea fx:id="areaResultado" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
</VBox>
