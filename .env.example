# ============================================================
# GaliciaWear — Variables de entorno (PLANTILLA)
# Copia este fichero a `.env` y rellena con valores reales.
# NUNCA subas el `.env` real al repositorio.
# ============================================================

# -------- Backend --------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# -------- Postgres (Docker Compose) --------
POSTGRES_USER=galiciawear
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=galiciawear
DATABASE_URL=postgresql://galiciawear:cambia-esto-en-produccion@localhost:5432/galiciawear?schema=public

# -------- Mongo (Docker Compose) --------
MONGO_USER=galiciawear
MONGO_PASSWORD=cambia-esto-en-produccion
MONGO_URL=mongodb://galiciawear:cambia-esto-en-produccion@localhost:27017/galiciawear?authSource=admin

# -------- Auth --------
JWT_SECRET=genera-uno-con-openssl-rand-base64-32
JWT_REFRESH_SECRET=otro-distinto-min-16-chars-genera-con-openssl
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------- CORS --------
CORS_ORIGIN=http://localhost:5173

# -------- OAuth2 Google (Fase 2 — OPCIONAL) --------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# -------- Firebase Cloud Messaging (Fase 4) --------
# Descarga la service account de la consola Firebase y guárdala en backend/secrets/firebase-admin.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-admin.json

# -------- Rate limiting (Fase 7) --------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
