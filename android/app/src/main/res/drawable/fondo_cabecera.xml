<?xml version="1.0" encoding="utf-8"?>
<!-- Degradado diagonal azul atlántico → celeste: evoca la banda de la bandera gallega -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="@color/primario_oscuro"
        android:centerColor="@color/primario"
        android:endColor="@color/celeste" />
</shape>
