<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/superficie_variante"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/superficie">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imagen_producto"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:scaleType="centerCrop"
            android:background="@color/superficie_variante"
            android:contentDescription="@string/imagen_producto"
            app:shapeAppearanceOverlay="@style/Forma.GaliciaWear.Media"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/texto_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/texto_primario"
            app:layout_constraintStart_toEndOf="@id/imagen_producto"
            app:layout_constraintTop_toTopOf="@id/imagen_producto"
            app:layout_constraintEnd_toStartOf="@id/boton_eliminar"
            android:layout_marginStart="12dp"
            tools:text="Camiseta de lino gallego" />

        <TextView
            android:id="@+id/texto_variante"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toEndOf="@id/imagen_producto"
            app:layout_constraintTop_toBottomOf="@id/texto_nombre"
            app:layout_constraintEnd_toStartOf="@id/boton_eliminar"
            tools:text="Talla M · Blanco" />

        <ImageButton
            android:id="@+id/boton_eliminar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_eliminar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/eliminar_item"
            android:scaleType="centerInside"
            app:layout_constraintTop_toTopOf="@id/imagen_producto"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Selector de cantidad: − N + -->
        <LinearLayout
            android:id="@+id/grupo_cantidad"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/fondo_stepper"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/imagen_producto"
            app:layout_constraintBottom_toBottomOf="@id/imagen_producto">

            <ImageButton
                android:id="@+id/boton_menos"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_menos"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="@string/restar_unidad" />

            <TextView
                android:id="@+id/texto_cantidad"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"
                tools:text="2" />

            <ImageButton
                android:id="@+id/boton_mas"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_mas"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="@string/sumar_unidad" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_precio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primario"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/imagen_producto"
            tools:text="59,98 €" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
