<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fondo"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/barra_herramientas"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/estudio_titulo"
            app:navigationIcon="@drawable/ic_volver" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Hero: CTA principal para crear una prenda -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tarjeta_hero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/fondo_cabecera"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estudio_hero_titulo"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/estudio_hero_subtitulo"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginTop="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_crear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/crear_prenda"
                android:textColor="@color/primario"
                app:icon="@drawable/ic_mas"
                app:iconTint="@color/primario"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Encabezado de la lista + contador -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mis_prendas"
            android:textColor="@color/texto_primario"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/texto_contador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_secundario"
            android:textSize="13sp"
            tools:text="4 prendas · 3 publicadas" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lista_prendas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="24dp" />

        <ProgressBar
            android:id="@+id/indicador_carga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primario"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/estado_vacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_placeholder_producto"
                app:tint="@color/celeste_claro"
                android:contentDescription="@string/sin_prendas" />

            <TextView
                android:id="@+id/texto_vacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sin_prendas"
                android:textColor="@color/texto_secundario"
                android:textSize="15sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="14dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
