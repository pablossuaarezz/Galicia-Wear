<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fondo"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/barra_herramientas"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/confirmar_pedido" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="110dp">

            <!-- ── Dirección de envío ─────────────────────────────────────── -->
            <TextView
                style="@style/EtiquetaSeccionCheckout"
                android:text="@string/direccion_envio" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/superficie_variante"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/superficie">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <RadioGroup
                        android:id="@+id/contenedor_direcciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/texto_sin_direcciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sin_direcciones"
                        android:textColor="@color/texto_secundario"
                        android:textSize="14sp"
                        android:padding="12dp"
                        android:visibility="gone" />

                    <!-- Botón para desplegar el formulario de alta -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_anadir_direccion"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/anadir_direccion"
                        app:icon="@drawable/ic_mas"
                        app:iconGravity="textStart" />

                    <!-- ── Formulario de nueva dirección (oculto por defecto) ── -->
                    <LinearLayout
                        android:id="@+id/formulario_direccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/nueva_direccion"
                            android:textColor="@color/texto_primario"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/alias_direccion">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/entrada_alias"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/direccion_linea1">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/entrada_linea1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPostalAddress"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/direccion_linea2">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/entrada_linea2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPostalAddress"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:hint="@string/codigo_postal">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/entrada_cp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:maxLength="5"
                                    android:maxLines="1" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:hint="@string/ciudad">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/entrada_ciudad"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textCapWords"
                                    android:maxLines="1" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/provincia">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/entrada_provincia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:text="@string/provincia_por_defecto"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="end"
                            android:layout_marginTop="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/boton_cancelar_direccion"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cancelar" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/boton_guardar_direccion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/guardar_direccion" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Método de pago (selector) ──────────────────────────────── -->
            <TextView
                style="@style/EtiquetaSeccionCheckout"
                android:text="@string/metodo_pago" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_metodo_pago"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/metodo_pago">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/selector_metodo_pago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    tools:ignore="LabelFor" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Método de envío (selector) ─────────────────────────────── -->
            <TextView
                style="@style/EtiquetaSeccionCheckout"
                android:text="@string/tipo_envio" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_metodo_envio"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/tipo_envio">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/selector_metodo_envio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    tools:ignore="LabelFor" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Resumen del pedido ─────────────────────────────────────── -->
            <TextView
                style="@style/EtiquetaSeccionCheckout"
                android:text="@string/resumen_pedido" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/superficie_variante"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/superficie">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/texto_subtotal_etiqueta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/subtotal"
                            android:textColor="@color/texto_secundario"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/texto_subtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_primario"
                            android:textSize="15sp"
                            tools:text="89,97 €" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/envio"
                            android:textColor="@color/texto_secundario"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/texto_coste_envio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/envio_gratis"
                            android:textColor="@color/verde_sostenible"
                            android:textStyle="bold"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total"
                            android:textColor="@color/texto_primario"
                            android:textStyle="bold"
                            android:textSize="18sp" />
                        <TextView
                            android:id="@+id/texto_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/primario"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            tools:text="89,97 €" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/indicador_carga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primario"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/boton_confirmar_pedido"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/confirmar_pedido"
        android:textSize="16sp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cornerRadius="28dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
