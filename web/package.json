{
  "name": "galiciawear-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Storefront público + dashboard de diseñador de GaliciaWear",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --ext ts,tsx --max-warnings=0",
